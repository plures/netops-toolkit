<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      color: #1e293b;
      background: #f8fafc;
      padding: 24px;
    }
    h1 { font-size: 22px; font-weight: 700; }
    h2 { font-size: 17px; font-weight: 600; margin: 28px 0 12px; }
    h3 { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
    p  { color: #64748b; font-size: 13px; }

    /* ---- Layout ---- */
    .page-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      margin-bottom: 24px;
    }
    .badge {
      display: inline-block; padding: 4px 10px; border-radius: 9999px;
      font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;
    }
    .badge-ok    { background: #dcfce7; color: #166534; }
    .badge-alert { background: #fee2e2; color: #991b1b; }

    /* ---- Summary cards ---- */
    .cards { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 32px; }
    .card {
      background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
      padding: 16px 20px; flex: 1 1 200px; min-width: 180px;
    }
    .card-alert { border-left: 4px solid #ef4444; }
    .card-ok    { border-left: 4px solid #22c55e; }
    .card-metric { font-size: 28px; font-weight: 700; margin: 6px 0 4px; }
    .card-metric-alert { color: #ef4444; }
    .card-metric-ok    { color: #22c55e; }
    .card-sub { font-size: 12px; color: #94a3b8; }

    /* ---- Tables ---- */
    .section-box {
      background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
      margin-bottom: 28px; overflow: hidden;
    }
    .section-title {
      padding: 12px 16px; background: #f1f5f9;
      border-bottom: 1px solid #e2e8f0;
      display: flex; align-items: center; gap: 8px;
    }
    table { width: 100%; border-collapse: collapse; }
    th {
      text-align: left; padding: 10px 14px; font-size: 12px;
      font-weight: 600; text-transform: uppercase; letter-spacing: .05em;
      color: #64748b; background: #f8fafc; border-bottom: 1px solid #e2e8f0;
    }
    td { padding: 9px 14px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr.row-alert td { background: #fff5f5; }
    tr:hover td { background: #f8fafc; }

    /* ---- Status cell ---- */
    .status-ok    { color: #16a34a; font-weight: 600; }
    .status-alert { color: #dc2626; font-weight: 600; }
    .status-warn  { color: #d97706; font-weight: 600; }
    .status-na    { color: #94a3b8; }

    /* ---- Progress bar ---- */
    .bar-wrap { display: flex; align-items: center; gap: 8px; }
    .bar-bg {
      flex: 1; height: 8px; background: #e2e8f0; border-radius: 4px; overflow: hidden;
    }
    .bar-fill { height: 100%; border-radius: 4px; }
    .bar-ok      { background: #22c55e; }
    .bar-warn    { background: #f59e0b; }
    .bar-alert   { background: #ef4444; }
    .bar-label   { font-size: 12px; font-weight: 600; min-width: 42px; text-align: right; }

    /* ---- Unreachable row ---- */
    .row-unreachable td { color: #94a3b8; font-style: italic; }

    /* ---- Footer ---- */
    .footer { margin-top: 40px; font-size: 12px; color: #94a3b8; text-align: center; }
  </style>
</head>
<body>

{# ------------------------------------------------------------------ #}
{# Macros                                                              #}
{# ------------------------------------------------------------------ #}

{% macro status_badge(alert) %}
  {% if alert %}
    <span class="badge badge-alert">&#x26A0; Alert</span>
  {% else %}
    <span class="badge badge-ok">&#x2714; OK</span>
  {% endif %}
{% endmacro %}

{% macro pct_bar(value, threshold) %}
  {% if value is none %}
    <span class="status-na">N/A</span>
  {% else %}
    {% set cls = "bar-alert" if value >= threshold else ("bar-warn" if value >= threshold * 0.8 else "bar-ok") %}
    {% set pct = [value, 100] | min %}
    <div class="bar-wrap">
      <div class="bar-bg"><div class="bar-fill {{ cls }}" style="width:{{ pct }}%"></div></div>
      <span class="bar-label {% if value >= threshold %}status-alert{% endif %}">{{ "%.1f"|format(value) }}%</span>
    </div>
  {% endif %}
{% endmacro %}

{# ------------------------------------------------------------------ #}
{# Page header                                                         #}
{# ------------------------------------------------------------------ #}

<div class="page-header">
  <div>
    <h1>{{ title }}</h1>
    <p>Generated: {{ generated_at }}{% if period %} &nbsp;&#x2022;&nbsp; Period: {{ period }}{% endif %}</p>
  </div>
  <div>{{ status_badge(overall_alert) }}</div>
</div>

{# ------------------------------------------------------------------ #}
{# Summary cards                                                       #}
{# ------------------------------------------------------------------ #}

<div class="cards">
{% for section in sections %}
  {% set d = section.data %}
  {% set has_alert = d.overall_alert %}
  <div class="card {% if has_alert %}card-alert{% else %}card-ok{% endif %}">
    <h3>{{ section.name }}</h3>
    {% if section.type == "health" %}
      <div class="card-metric {% if has_alert %}card-metric-alert{% else %}card-metric-ok{% endif %}">
        {{ d.devices_reachable }}/{{ d.devices }}
      </div>
      <div class="card-sub">devices reachable</div>
      {% if d.devices_with_alerts > 0 %}
        <div class="card-sub" style="color:#dc2626;margin-top:4px">{{ d.devices_with_alerts }} with alerts</div>
      {% endif %}
    {% elif section.type == "bgp" %}
      <div class="card-metric {% if has_alert %}card-metric-alert{% else %}card-metric-ok{% endif %}">
        {{ d.established }}/{{ d.total_peers }}
      </div>
      <div class="card-sub">peers established</div>
      {% if d.not_established > 0 %}
        <div class="card-sub" style="color:#dc2626;margin-top:4px">{{ d.not_established }} down</div>
      {% endif %}
    {% elif section.type == "vlan" %}
      <div class="card-metric {% if has_alert %}card-metric-alert{% else %}card-metric-ok{% endif %}">
        {{ d.switches_compliant }}/{{ d.switches }}
      </div>
      <div class="card-sub">switches compliant</div>
    {% else %}
      <div class="card-metric {% if has_alert %}card-metric-alert{% else %}card-metric-ok{% endif %}">
        {{ "Alert" if has_alert else "OK" }}
      </div>
    {% endif %}
    <div style="margin-top:10px">{{ status_badge(has_alert) }}</div>
  </div>
{% endfor %}
</div>

{# ------------------------------------------------------------------ #}
{# Detailed sections                                                   #}
{# ------------------------------------------------------------------ #}

{% for section in sections %}
<h2>{{ section.name }}</h2>
{% set d = section.data %}

{# ---- Health section ---- #}
{% if section.type == "health" %}
<div class="section-box">
  <div class="section-title">
    <h3>Device Health Summary</h3>
    {{ status_badge(d.overall_alert) }}
  </div>
  <table>
    <thead>
      <tr>
        <th>Host</th>
        <th>Status</th>
        <th>CPU</th>
        <th>Memory</th>
        <th>Interface Errors</th>
        <th>Log Events</th>
      </tr>
    </thead>
    <tbody>
    {% for r in d.results %}
      {% set alert = r.overall_alert %}
      <tr {% if not r.success %}class="row-unreachable"{% elif alert %}class="row-alert"{% endif %}>
        <td><strong>{{ r.host }}</strong></td>
        <td>
          {% if not r.success %}
            <span class="status-alert">Unreachable</span>
          {% elif alert %}
            <span class="status-alert">&#x26A0; Alert</span>
          {% else %}
            <span class="status-ok">&#x2714; OK</span>
          {% endif %}
        </td>
        {% if r.success %}
          {% set cpu = r.checks.get("cpu", {}) %}
          {% set mem = r.checks.get("memory", {}) %}
          {% set iface = r.checks.get("interface_errors", {}) %}
          {% set logs = r.checks.get("logs", {}) %}
          <td>{{ pct_bar(cpu.get("utilization"), cpu.get("threshold", 80)) }}</td>
          <td>{{ pct_bar(mem.get("utilization"), mem.get("threshold", 85)) }}</td>
          <td>
            {% set w = iface.get("with_errors", 0) %}
            {% set t = iface.get("total", 0) %}
            {% if iface.get("alert") %}
              <span class="status-alert">{{ w }}/{{ t }}</span>
            {% else %}
              <span class="status-ok">{{ w }}/{{ t }}</span>
            {% endif %}
          </td>
          <td>
            {% if logs.get("alert") %}
              <span class="status-alert">{{ logs.get("critical_count", 0) }} crit / {{ logs.get("major_count", 0) }} major</span>
            {% else %}
              <span class="status-ok">{{ logs.get("critical_count", 0) }} crit / {{ logs.get("major_count", 0) }} major</span>
            {% endif %}
          </td>
        {% else %}
          <td colspan="4" class="status-na">{{ r.get("error", "Connection failed") }}</td>
        {% endif %}
      </tr>
    {% else %}
      <tr><td colspan="6" class="status-na" style="text-align:center">No results</td></tr>
    {% endfor %}
    </tbody>
  </table>
</div>

{# ---- BGP section ---- #}
{% elif section.type == "bgp" %}
<div class="section-box">
  <div class="section-title">
    <h3>BGP Peers — {{ d.routers_reachable }}/{{ d.routers }} routers reachable</h3>
    {{ status_badge(d.overall_alert) }}
  </div>
  <table>
    <thead>
      <tr>
        <th>Router</th>
        <th>Neighbor</th>
        <th>Peer AS</th>
        <th>State</th>
        <th>Uptime</th>
        <th>Prefixes Rcvd</th>
        <th>Alerts</th>
      </tr>
    </thead>
    <tbody>
    {% for peer in d.peers %}
      {% set row_alert = not peer.is_established or peer.is_flapping or peer.prefix_alert %}
      <tr {% if row_alert %}class="row-alert"{% endif %}>
        <td>{{ peer.get("router", "—") }}</td>
        <td><code>{{ peer.neighbor }}</code></td>
        <td>{{ peer.peer_as }}</td>
        <td>
          {% if peer.is_established %}
            {% if peer.is_flapping %}
              <span class="status-warn">&#x26A0; Flapping</span>
            {% else %}
              <span class="status-ok">Established</span>
            {% endif %}
          {% else %}
            <span class="status-alert">{{ peer.state }}</span>
          {% endif %}
        </td>
        <td>{{ peer.get("up_down", "—") }}</td>
        <td>
          {% set pr = peer.get("prefixes_received") %}
          {% set ep = peer.get("expected_prefixes") %}
          {% if pr is not none %}
            {% if peer.prefix_alert %}
              <span class="status-alert">{{ pr }}{% if ep is not none %}/{{ ep }}{% endif %}</span>
            {% else %}
              {{ pr }}{% if ep is not none %}/{{ ep }}{% endif %}
            {% endif %}
          {% else %}
            <span class="status-na">—</span>
          {% endif %}
        </td>
        <td>
          {% if peer.alerts %}
            {% for a in peer.alerts %}
              <div class="status-alert" style="font-size:12px">&#x26A0; {{ a }}</div>
            {% endfor %}
          {% else %}
            <span class="status-ok" style="font-size:12px">&#x2714; None</span>
          {% endif %}
        </td>
      </tr>
    {% else %}
      <tr><td colspan="7" class="status-na" style="text-align:center">No peers</td></tr>
    {% endfor %}
    </tbody>
  </table>
</div>

{# ---- VLAN section ---- #}
{% elif section.type == "vlan" %}
<div class="section-box">
  <div class="section-title">
    <h3>VLAN Audit — {{ d.switches_compliant }}/{{ d.switches }} switches compliant</h3>
    {{ status_badge(d.overall_alert) }}
  </div>
  <table>
    <thead>
      <tr>
        <th>Switch</th>
        <th>Status</th>
        <th>Missing VLANs</th>
        <th>Extra VLANs</th>
        <th>Name Mismatches</th>
        <th>Trunk Mismatches</th>
      </tr>
    </thead>
    <tbody>
    {% set all_results = d.get("results", []) %}
    {% for r in all_results %}
      {% set row_alert = not r.get("compliant", True) %}
      <tr {% if not r.get("success") %}class="row-unreachable"{% elif row_alert %}class="row-alert"{% endif %}>
        <td><strong>{{ r.host }}</strong></td>
        <td>
          {% if not r.get("success") %}
            <span class="status-alert">Unreachable</span>
          {% elif r.get("compliant") %}
            <span class="status-ok">&#x2714; Compliant</span>
          {% else %}
            <span class="status-alert">&#x26A0; Non-Compliant</span>
          {% endif %}
        </td>
        {% if r.get("success") %}
          <td>
            {% if r.missing_vlans %}
              <span class="status-alert">{{ r.missing_vlans | join(", ") }}</span>
            {% else %}<span class="status-na">—</span>{% endif %}
          </td>
          <td>
            {% if r.extra_vlans %}
              <span class="status-warn">{{ r.extra_vlans | join(", ") }}</span>
            {% else %}<span class="status-na">—</span>{% endif %}
          </td>
          <td>
            {% if r.name_mismatches %}
              <span class="status-warn">{{ r.name_mismatches | length }}</span>
            {% else %}<span class="status-na">—</span>{% endif %}
          </td>
          <td>
            {% if r.trunk_mismatches %}
              <span class="status-warn">{{ r.trunk_mismatches | length }}</span>
            {% else %}<span class="status-na">—</span>{% endif %}
          </td>
        {% else %}
          <td colspan="4" class="status-na">{{ r.get("error", "Connection failed") }}</td>
        {% endif %}
      </tr>
    {% else %}
      <tr><td colspan="6" class="status-na" style="text-align:center">No results</td></tr>
    {% endfor %}
    </tbody>
  </table>
</div>

{# ---- Generic/unknown section ---- #}
{% else %}
<div class="section-box">
  <div class="section-title">
    <h3>{{ section.name }}</h3>
    {{ status_badge(d.overall_alert) }}
  </div>
  <div style="padding:16px;color:#64748b">
    <pre style="font-size:12px;white-space:pre-wrap">{{ d | tojson(indent=2) }}</pre>
  </div>
</div>
{% endif %}

{% endfor %}

<div class="footer">
  Generated by netops-toolkit &mdash; {{ generated_at }}
</div>

</body>
</html>
