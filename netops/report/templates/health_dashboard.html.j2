<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Network Health Dashboard</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      color: #1e293b;
      background: #f8fafc;
      padding: 24px;
    }
    h1 { font-size: 22px; font-weight: 700; }
    h2 { font-size: 17px; font-weight: 600; margin: 28px 0 12px; }
    h3 { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
    p  { color: #64748b; font-size: 13px; }

    /* ---- Layout ---- */
    .page-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      margin-bottom: 24px;
    }
    .badge {
      display: inline-block; padding: 4px 10px; border-radius: 9999px;
      font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;
    }
    .badge-ok   { background: #dcfce7; color: #166534; }
    .badge-warn { background: #fef9c3; color: #854d0e; }
    .badge-crit { background: #fee2e2; color: #991b1b; }

    /* ---- Summary cards ---- */
    .cards { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 32px; }
    .card {
      background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
      padding: 16px 20px; flex: 1 1 180px; min-width: 160px;
    }
    .card-crit { border-left: 4px solid #ef4444; }
    .card-warn { border-left: 4px solid #f59e0b; }
    .card-ok   { border-left: 4px solid #22c55e; }
    .card-metric { font-size: 28px; font-weight: 700; margin: 6px 0 4px; }
    .card-metric-crit { color: #ef4444; }
    .card-metric-warn { color: #f59e0b; }
    .card-metric-ok   { color: #22c55e; }
    .card-sub { font-size: 12px; color: #94a3b8; }

    /* ---- Filters bar ---- */
    .filter-bar {
      background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 6px;
      padding: 10px 14px; margin-bottom: 20px; font-size: 13px; color: #475569;
    }
    .filter-bar strong { color: #1e293b; }

    /* ---- Tables ---- */
    .section-box {
      background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
      margin-bottom: 28px; overflow: hidden;
    }
    .section-title {
      padding: 12px 16px; background: #f1f5f9;
      border-bottom: 1px solid #e2e8f0;
      display: flex; align-items: center; gap: 8px;
    }
    table { width: 100%; border-collapse: collapse; }
    th {
      text-align: left; padding: 10px 14px; font-size: 12px;
      font-weight: 600; text-transform: uppercase; letter-spacing: .05em;
      color: #64748b; background: #f8fafc; border-bottom: 1px solid #e2e8f0;
    }
    td { padding: 9px 14px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr.row-crit td { background: #fff5f5; }
    tr.row-warn td { background: #fffbeb; }
    tr:hover td { background: #f8fafc; }

    /* ---- Status ---- */
    .status-ok   { color: #16a34a; font-weight: 600; }
    .status-warn { color: #d97706; font-weight: 600; }
    .status-crit { color: #dc2626; font-weight: 600; }
    .status-na   { color: #94a3b8; }

    /* ---- Top issues ---- */
    .issue-pill {
      display: inline-block; background: #fee2e2; color: #991b1b;
      border-radius: 9999px; padding: 2px 8px; font-size: 11px;
      font-weight: 600; margin: 2px 2px 0 0;
    }

    /* ---- Footer ---- */
    .footer { margin-top: 40px; font-size: 12px; color: #94a3b8; text-align: center; }

    @media print {
      body { background: #fff; padding: 8px; }
      .section-box { break-inside: avoid; }
    }
  </style>
</head>
<body>

{# ------------------------------------------------------------------ #}
{# Macros                                                              #}
{# ------------------------------------------------------------------ #}

{% macro status_badge(status) %}
  {% if status == "crit" %}
    <span class="badge badge-crit">&#x26A0; Critical</span>
  {% elif status == "warn" %}
    <span class="badge badge-warn">&#x26A0; Warning</span>
  {% else %}
    <span class="badge badge-ok">&#x2714; OK</span>
  {% endif %}
{% endmacro %}

{% macro status_cell(status) %}
  {% if status == "crit" %}
    <span class="status-crit">&#x26A0; CRIT</span>
  {% elif status == "warn" %}
    <span class="status-warn">&#x26A0; WARN</span>
  {% else %}
    <span class="status-ok">&#x2714; OK</span>
  {% endif %}
{% endmacro %}

{# ------------------------------------------------------------------ #}
{# Page header                                                         #}
{# ------------------------------------------------------------------ #}

<div class="page-header">
  <div>
    <h1>Network Health Dashboard</h1>
    <p>Generated: {{ generated_at }}</p>
  </div>
  <div>{{ status_badge(overall_status) }}</div>
</div>

{# ------------------------------------------------------------------ #}
{# Active filters                                                      #}
{# ------------------------------------------------------------------ #}

{% set fv = filters.get("vendor") %}
{% set fs = filters.get("site") %}
{% set fsev = filters.get("severity") %}
{% if fv or fs or fsev %}
<div class="filter-bar">
  <strong>Active filters:</strong>
  {% if fv %} Vendor = <strong>{{ fv }}</strong>{% endif %}
  {% if fs %} &nbsp;&#x2022;&nbsp; Site = <strong>{{ fs }}</strong>{% endif %}
  {% if fsev %} &nbsp;&#x2022;&nbsp; Severity &ge; <strong>{{ fsev }}</strong>{% endif %}
</div>
{% endif %}

{# ------------------------------------------------------------------ #}
{# Summary cards                                                       #}
{# ------------------------------------------------------------------ #}

{% set s = summary %}
{% set health_cls = "card-" + overall_status %}
{% set health_metric_cls = "card-metric-" + overall_status %}

<div class="cards">
  <div class="card {{ health_cls }}">
    <h3>Healthy Devices</h3>
    <div class="card-metric {{ health_metric_cls }}">
      {{ s.healthy_devices }}/{{ s.total_devices }}
    </div>
    <div class="card-sub">{{ s.pct_healthy }}% healthy</div>
    {% if s.unreachable_devices > 0 %}
      <div class="card-sub" style="color:#dc2626;margin-top:4px">
        {{ s.unreachable_devices }} unreachable
      </div>
    {% endif %}
    <div style="margin-top:10px">{{ status_badge(overall_status) }}</div>
  </div>

  <div class="card {% if s.checks_crit > 0 %}card-crit{% elif s.checks_warn > 0 %}card-warn{% else %}card-ok{% endif %}">
    <h3>Check Results</h3>
    <div class="card-metric {% if s.checks_crit > 0 %}card-metric-crit{% elif s.checks_warn > 0 %}card-metric-warn{% else %}card-metric-ok{% endif %}">
      {{ s.checks_ok + s.checks_warn + s.checks_crit }}
    </div>
    <div class="card-sub">
      <span class="status-ok">{{ s.checks_ok }} OK</span>
      &nbsp;&#x2022;&nbsp;
      <span class="status-warn">{{ s.checks_warn }} WARN</span>
      &nbsp;&#x2022;&nbsp;
      <span class="status-crit">{{ s.checks_crit }} CRIT</span>
    </div>
  </div>

  {% if s.top_issues %}
  <div class="card card-crit">
    <h3>Top Issues</h3>
    <div style="margin-top:8px">
      {% for issue in s.top_issues %}
        <span class="issue-pill">{{ issue.category }} ({{ issue.count }})</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>

{# ------------------------------------------------------------------ #}
{# Entry table                                                         #}
{# ------------------------------------------------------------------ #}

<h2>Check Details</h2>
<div class="section-box">
  <div class="section-title">
    <h3>All Check Results</h3>
    {{ status_badge(overall_status) }}
    <span style="margin-left:auto;font-size:12px;color:#64748b">{{ entries | length }} rows</span>
  </div>
  <table>
    <thead>
      <tr>
        <th>Device</th>
        <th>Vendor</th>
        <th>Site</th>
        <th>Category</th>
        <th>Status</th>
        <th>Detail</th>
        <th>Timestamp</th>
      </tr>
    </thead>
    <tbody>
    {% for entry in entries %}
      <tr {% if entry.status == "crit" %}class="row-crit"{% elif entry.status == "warn" %}class="row-warn"{% endif %}>
        <td><strong>{{ entry.device }}</strong></td>
        <td><span style="font-size:12px;color:#64748b">{{ entry.vendor or "—" }}</span></td>
        <td><span style="font-size:12px;color:#64748b">{{ entry.site or "—" }}</span></td>
        <td><code style="font-size:12px">{{ entry.category }}</code></td>
        <td>{{ status_cell(entry.status) }}</td>
        <td style="font-size:13px">{{ entry.detail }}</td>
        <td style="font-size:11px;color:#94a3b8">{{ entry.timestamp }}</td>
      </tr>
    {% else %}
      <tr><td colspan="7" class="status-na" style="text-align:center;padding:24px">
        No entries match the current filters.
      </td></tr>
    {% endfor %}
    </tbody>
  </table>
</div>

<div class="footer">
  Generated by netops-toolkit &mdash; {{ generated_at }}
</div>

</body>
</html>
